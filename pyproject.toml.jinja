[project]
name = "{{ project_slug }}"
version = "0.1.0"
description = "Generated by Copier template"

[project.optional-dependencies]
dev = [
    "{{ pre_commit_tool }}",{% if project_slug == "project_template" %}
    "copier",{% endif %}
]

[tool.setuptools]{% if package_or_app == 'package' %}
package-dir = { "" = "src" }
{% else %}
package-dir = { "" = "." }
{% endif %}
[build-system]
requires = ["setuptools", "wheel"]
build-backend = "setuptools.build_meta"

[tool.ruff]
line-length = 88

[tool.ruff.lint]
select = ["ALL"]
ignore = [
    "COM812",
    "D203",
    "D212",
    "S311",
]

[tool.mypy]
ignore_missing_imports = true
