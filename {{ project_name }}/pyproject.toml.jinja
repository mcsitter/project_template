[project]
name = "{{ project_name }}"
version = "0.1.0"
description = "Generated by Copier template"

[project.optional-dependencies]
dev = ["{{ pre_commit_tool }}"]

{% if src_layout %}
[tool.setuptools]
package-dir = { "" = "src" }

{% endif %}
[build-system]
requires = ["setuptools", "wheel"]
build-backend = "setuptools.build_meta"

[tool.ruff]
line-length = 88
select = ["E", "F", "W", "C90"]

[tool.mypy]
ignore_missing_imports = true
